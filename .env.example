# Copy to .env for local runs, or set these as Railway service variables.
# NEVER commit real values — .env is gitignored.

# Port Railway injects automatically in prod; 8080 for local.
PORT=8080

# Client read token. The softphone sends this as the "X-Arabicss-Token" header.
# If unset, /api/version is served openly (dev only). Set it in prod.
# This is a throttle, not a true secret (it ships inside the client binary).
UPDATE_API_TOKEN=replace-with-a-long-random-string

# Webhook secret the GitHub release pipeline uses to POST /api/manifest.
# A genuine server-side secret — never ship this to a client.
WEBHOOK_SECRET=replace-with-a-different-long-random-string
